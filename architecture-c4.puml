@startuml C4_Context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

LAYOUT_WITH_LEGEND()

title System Context Diagram for Foundry Local LLM Server

Person(user, "User", "Developer or application using LLM services")

System_Boundary(foundry_server, "Foundry Local LLM Server") {
    Container(frontend, "Web Frontend", "Vite/TypeScript", "Provides UI for interacting with LLM services")
    Container(server, "API Server", "ASP.NET Core", "OpenAI-compatible API proxy that manages requests to Foundry Local")
}

System_Ext(foundry, "Foundry Local", "Local LLM inference service (GPU/CPU)")
System_Ext(foundry_cli, "Foundry CLI", "Command-line tool for service discovery and model management")

Rel(user, frontend, "Uses", "HTTPS")
Rel(user, server, "Sends API requests", "HTTPS/OpenAI API")
Rel(frontend, server, "Calls API", "HTTP/REST")
Rel(server, foundry, "Proxies chat completions", "HTTP/OpenAI API")
Rel(server, foundry_cli, "Discovers endpoint, loads models", "Process execution")
Rel(foundry_cli, foundry, "Manages", "CLI commands")

note right of server
  - Auto-discovers Foundry endpoint
  - Resolves model aliases to IDs
  - Caps max_tokens to prevent OOM
  - Serializes streaming requests
  - Handles connection failures with retry
end note

note right of foundry
  - Runs models locally (CUDA/GPU/CPU)
  - Provides /v1/models endpoint
  - Provides /v1/chat/completions
  - Can crash on concurrent streams
end note

@enduml
